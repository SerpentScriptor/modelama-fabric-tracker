# Postgres connection string.
# Railway/Render fill this in automatically when you attach a Postgres database -
# you usually do NOT need to set this by hand on those platforms.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Set SSL on for hosted Postgres (Railway/Render/most cloud DBs need this).
PGSSL=true

# Shared passcode everyone on your team enters once to open the dashboard.
# Change this to something private before you deploy.
APP_PASSWORD=change-this-passcode

# Port the server listens on. Railway/Render set this automatically; safe to leave as-is locally.
PORT=3000
